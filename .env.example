PORT=3000
# Optional global verify token fallback (per-project tokens are preferred).
VERIFY_TOKEN=replace_me
# Meta app secret used to verify x-hub-signature-256.
APP_SECRET=replace_me
# Optional comma-separated list of additional app secrets for multi-app webhook setups.
APP_SECRETS=
# Optional metadata fields for deployment clarity.
META_APP_ID=replace_me
META_APP_SECRET=replace_me
INSTAGRAM_APP_ID=replace_me
INSTAGRAM_APP_SECRET=replace_me
FACEBOOK_APP_ID=replace_me
FACEBOOK_APP_SECRET=replace_me
WHATSAPP_APP_ID=replace_me
WHATSAPP_APP_SECRET=replace_me
# Shared secret expected by downstream internal webhook endpoint.
INTERNAL_SECRET=replace_me
FORWARD_TIMEOUT_MS=8000
FORWARD_MAX_ATTEMPTS=3
QUEUE_MAX_ATTEMPTS=5
QUEUE_BASE_RETRY_DELAY_MS=500
BODY_LIMIT=1mb

# Resolver refresh interval for project routing index.
PROJECT_RESOLVER_REFRESH_MS=60000
# Optional DB collection name override (defaults to "socialintegrations").
PROJECT_INTEGRATIONS_COLLECTION=socialintegrations

# Option A (recommended): JSON array with all projects (supports any count, e.g. 3).
# PROJECT_DBS_JSON=[{"projectId":"project-a","mongoUri":"mongodb+srv://...","verifyToken":"token-a","backendWebhookUrls":{"instagram":"https://project-a-backend.onrender.com/api/v1/webhooks/instagram","facebook":"https://project-a-backend.onrender.com/api/v1/social-integrations/messenger/webhook","whatsapp":"https://project-a-backend.onrender.com/api/v1/social-integrations/whatsapp/webhook"}},{"projectId":"project-b","mongoUri":"mongodb+srv://...","verifyToken":"token-b","backendWebhookUrls":{"instagram":"https://project-b-backend.onrender.com/api/v1/webhooks/instagram","facebook":"https://project-b-backend.onrender.com/api/v1/social-integrations/messenger/webhook","whatsapp":"https://project-b-backend.onrender.com/api/v1/social-integrations/whatsapp/webhook"}},{"projectId":"project-c","mongoUri":"mongodb+srv://...","verifyToken":"token-c","backendWebhookUrls":{"instagram":"https://project-c-backend.onrender.com/api/v1/webhooks/instagram","facebook":"https://project-c-backend.onrender.com/api/v1/social-integrations/messenger/webhook","whatsapp":"https://project-c-backend.onrender.com/api/v1/social-integrations/whatsapp/webhook"}}]
PROJECT_DBS_JSON=

# Option B: indexed configuration (used when PROJECT_DBS_JSON is empty).
# Add one block per project using the same index number (1, 2, 3, ...).

# --- Project 1 ---
# MONGODB_URI_1=mongodb+srv://.../ProjectADb
# PROJECT_ID_1=project-a
# PROJECT_BACKEND_BASE_URL_1=https://project-a-backend.onrender.com
# OR provide explicit webhook URLs per platform:
# INSTAGRAM_WEBHOOK_URL_1=https://project-a-backend.onrender.com/api/v1/webhooks/instagram
# FACEBOOK_WEBHOOK_URL_1=https://project-a-backend.onrender.com/api/v1/social-integrations/messenger/webhook
# WHATSAPP_WEBHOOK_URL_1=https://project-a-backend.onrender.com/api/v1/social-integrations/whatsapp/webhook
# PROJECT_VERIFY_TOKEN_1=replace_me

# --- Project 2 ---
# MONGODB_URI_2=mongodb+srv://.../ProjectBDb
# PROJECT_ID_2=project-b
# PROJECT_BACKEND_BASE_URL_2=https://project-b-backend.onrender.com
# INSTAGRAM_WEBHOOK_URL_2=https://project-b-backend.onrender.com/api/v1/webhooks/instagram
# FACEBOOK_WEBHOOK_URL_2=https://project-b-backend.onrender.com/api/v1/social-integrations/messenger/webhook
# WHATSAPP_WEBHOOK_URL_2=https://project-b-backend.onrender.com/api/v1/social-integrations/whatsapp/webhook
# PROJECT_VERIFY_TOKEN_2=replace_me

# --- Project 3 ---
# MONGODB_URI_3=mongodb+srv://.../ProjectCDb
# PROJECT_ID_3=project-c
# PROJECT_BACKEND_BASE_URL_3=https://project-c-backend.onrender.com
# INSTAGRAM_WEBHOOK_URL_3=https://project-c-backend.onrender.com/api/v1/webhooks/instagram
# FACEBOOK_WEBHOOK_URL_3=https://project-c-backend.onrender.com/api/v1/social-integrations/messenger/webhook
# WHATSAPP_WEBHOOK_URL_3=https://project-c-backend.onrender.com/api/v1/social-integrations/whatsapp/webhook
# PROJECT_VERIFY_TOKEN_3=replace_me
