PORT=3000
# Optional global verify token fallback (per-client tokens are preferred).
VERIFY_TOKEN=replace_me
# Meta app secret used to verify x-hub-signature-256.
APP_SECRET=replace_me
# Optional comma-separated list of additional app secrets for multi-app webhook setups.
APP_SECRETS=
# Optional metadata fields for deployment clarity.
META_APP_ID=replace_me
META_APP_SECRET=replace_me
INSTAGRAM_APP_ID=replace_me
INSTAGRAM_APP_SECRET=replace_me
FACEBOOK_APP_ID=replace_me
FACEBOOK_APP_SECRET=replace_me
WHATSAPP_APP_ID=replace_me
WHATSAPP_APP_SECRET=replace_me
# Shared secret expected by downstream internal webhook endpoint.
INTERNAL_SECRET=replace_me
FORWARD_TIMEOUT_MS=8000
FORWARD_MAX_ATTEMPTS=3
QUEUE_MAX_ATTEMPTS=5
QUEUE_BASE_RETRY_DELAY_MS=500
BODY_LIMIT=1mb

# Resolver refresh interval for project routing index.
PROJECT_RESOLVER_REFRESH_MS=60000
# Optional DB collection name override (defaults to "socialintegrations").
PROJECT_INTEGRATIONS_COLLECTION=socialintegrations
# JSON array of project DB sources and target webhook URLs.
# Example:
# PROJECT_DBS_JSON=[{"projectId":"mammamia","mongoUri":"mongodb+srv://...","backendWebhookUrls":{"instagram":"https://mammamia-backend.onrender.com/api/v1/webhooks/instagram","facebook":"https://mammamia-backend.onrender.com/api/v1/social-integrations/messenger/webhook","whatsapp":"https://mammamia-backend.onrender.com/api/v1/social-integrations/whatsapp/webhook"}}]
PROJECT_DBS_JSON=

# Alternative indexed configuration (used when PROJECT_DBS_JSON is empty):
# MONGODB_URI_1=mongodb+srv://.../DbA
# PROJECT_ID_1=mammamia
# PROJECT_BACKEND_BASE_URL_1=https://mammamia-backend.onrender.com
# OR provide explicit webhook URLs per platform:
# INSTAGRAM_WEBHOOK_URL_1=https://mammamia-backend.onrender.com/api/v1/webhooks/instagram
# FACEBOOK_WEBHOOK_URL_1=https://mammamia-backend.onrender.com/api/v1/social-integrations/messenger/webhook
# WHATSAPP_WEBHOOK_URL_1=https://mammamia-backend.onrender.com/api/v1/social-integrations/whatsapp/webhook
# PROJECT_VERIFY_TOKEN_1=replace_me
